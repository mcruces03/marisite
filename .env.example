# Public site URL — required in production for canonical URLs, sitemap, robots, and JSON-LD.
# Example: https://www.tudominio.com (no trailing slash)
NEXT_PUBLIC_SITE_URL=

# Optional: Google Search Console HTML tag verification (content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Professional Instagram (full URL) — footer, contact, navbar icon, JSON-LD sameAs
# Example: https://www.instagram.com/tu_perfil_profesional/
NEXT_PUBLIC_INSTAGRAM_URL=

# Optional: label shown next to Instagram in footer and contact (default: Instagram profesional)
# NEXT_PUBLIC_INSTAGRAM_LABEL=Mi perfil en Instagram

# Optional: LinkedIn profile URL for JSON-LD sameAs
# NEXT_PUBLIC_LINKEDIN_URL=
